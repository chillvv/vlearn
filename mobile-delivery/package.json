{
  "name": "aiweb-mobile-delivery",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "install:all": "npm --prefix packages/mobile install --legacy-peer-deps && npm --prefix tests/visual install",
    "mobile:dev": "npm --prefix packages/mobile run start",
    "mobile:web": "npm --prefix packages/mobile run web",
    "mobile:typecheck": "npm --prefix packages/mobile run typecheck",
    "visual:test": "npm --prefix tests/visual run test",
    "docs:serve": "python -m http.server 4177 -d ."
  }
}
