EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-publishable-key

# 数据访问模式：local_api 代表使用本地数据库和接口，supabase 代表直连云端
EXPO_PUBLIC_DATA_ACCESS_MODE=local_api

# 【重要】移动端联调说明：
# 手机真机或 Android 模拟器无法访问 localhost。
# 如果走本地数据库，请将这里的 IP 替换为你电脑的局域网 IP（例如 192.168.1.100）
# 对于 Android 原生模拟器，可以使用 http://10.0.2.2:8080/api
EXPO_PUBLIC_API_BASE=http://YOUR_LOCAL_IP:8080/api

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-publishable-key
VITE_DATA_ACCESS_MODE=local_api
VITE_API_BASE=http://YOUR_LOCAL_IP:8080/api
EXPO_PUBLIC_POSTHOG_KEY=phc_xxx
EXPO_PUBLIC_POSTHOG_HOST=https://app.posthog.com
EXPO_PUBLIC_SENTRY_DSN=https://example.ingest.sentry.io/project-id
