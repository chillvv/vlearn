{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AI Planner Input Schema v1",
  "type": "object",
  "required": [
    "request_id",
    "user",
    "session_constraints",
    "system_constraints",
    "questions"
  ],
  "properties": {
    "request_id": {
      "type": "string",
      "minLength": 1
    },
    "request_at": {
      "type": "string",
      "format": "date-time"
    },
    "user": {
      "type": "object",
      "required": [
        "user_id",
        "stats_7d",
        "stats_30d"
      ],
      "properties": {
        "user_id": {
          "type": "string",
          "minLength": 1
        },
        "stats_7d": {
          "$ref": "#/$defs/userStats"
        },
        "stats_30d": {
          "$ref": "#/$defs/userStats"
        },
        "subject_preference": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": true
    },
    "session_constraints": {
      "type": "object",
      "required": [
        "budget_count",
        "prefer_due",
        "subjects"
      ],
      "properties": {
        "budget_count": {
          "type": "integer",
          "minimum": 1
        },
        "prefer_due": {
          "type": "boolean"
        },
        "subjects": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": true
    },
    "system_constraints": {
      "type": "object",
      "required": [
        "min_interval_days",
        "max_session_count",
        "due_min_ratio",
        "archived_excluded"
      ],
      "properties": {
        "min_interval_days": {
          "type": "integer",
          "minimum": 0
        },
        "max_session_count": {
          "type": "integer",
          "minimum": 1
        },
        "due_min_ratio": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "archived_excluded": {
          "type": "boolean"
        }
      },
      "additionalProperties": true
    },
    "questions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/questionItem"
      }
    }
  },
  "$defs": {
    "userStats": {
      "type": "object",
      "required": [
        "review_count",
        "accuracy",
        "interruption_rate"
      ],
      "properties": {
        "review_count": {
          "type": "integer",
          "minimum": 0
        },
        "accuracy": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "interruption_rate": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      },
      "additionalProperties": true
    },
    "questionItem": {
      "type": "object",
      "required": [
        "question_id",
        "subject",
        "mastery_state",
        "review_count",
        "last_result",
        "last_interval_days",
        "lapse_count",
        "stability",
        "difficulty",
        "predicted_recall",
        "is_due",
        "is_archived"
      ],
      "properties": {
        "question_id": {
          "type": "string",
          "minLength": 1
        },
        "subject": {
          "type": "string",
          "enum": [
            "英语",
            "C语言"
          ]
        },
        "knowledge_point": {
          "type": "string"
        },
        "mastery_state": {
          "type": "string",
          "enum": [
            "active",
            "mastered",
            "archived"
          ]
        },
        "review_count": {
          "type": "integer",
          "minimum": 0
        },
        "last_result": {
          "type": "string",
          "enum": [
            "correct",
            "wrong",
            "unknown"
          ]
        },
        "last_interval_days": {
          "type": "number",
          "minimum": 0
        },
        "lapse_count": {
          "type": "integer",
          "minimum": 0
        },
        "stability": {
          "type": "number",
          "minimum": 0
        },
        "difficulty": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "predicted_recall": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "is_due": {
          "type": "boolean"
        },
        "is_archived": {
          "type": "boolean"
        }
      },
      "additionalProperties": true
    }
  }
}
